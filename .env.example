# Copy to .env (gitignored) — herrscher auto-loads it at startup and floods
# every command + plugin config. Real environment variables override these.
# Override the path with $HERRSCHER_ENV_FILE.

# --- Gateway: discord (required) ---
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=

# --- Backend: claude (optional; `claude` must be on PATH) ---
# CLAUDE_CMD=claude
# CLAUDE_MODEL=claude-haiku-4-5-20251001
# CLAUDE_STREAM=true

# --- Memory: obsidian (optional; unset = memory disabled) ---
# OBSIDIAN_VAULT=
